// packages/voice-db/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("VOICE_AGENT_DATABASE_URL")
}

model StoreSetting {
  id               String   @id @default(cuid())
  storeKey         String   @unique
  storeName        String
  greeting         String?
  timezone         String?  @default("America/New_York")
  hoursJson        Json?
  shippingPolicy   String?  @db.Text
  returnsPolicy    String?  @db.Text
  storePolicyNotes String?  @db.Text
  escalationPhone  String?
  shopifyDomain    String?
  shopifyAdminToken String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  faqItems         FaqItem[]
  callLogs         CallLog[]
  callbackBookings CallbackBooking[]
  callSessions     CallSession[]

  @@map("store_settings")
}

model FaqItem {
  id        String   @id @default(cuid())
  storeKey  String
  question  String
  answer    String   @db.Text
  category  String?
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store StoreSetting @relation(fields: [storeKey], references: [storeKey], onDelete: Cascade)

  @@index([storeKey])
  @@index([storeKey, isActive])
  @@map("faq_items")
}

enum VoiceCallStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  ESCALATED
}

model CallLog {
  id             String          @id @default(cuid())
  storeKey       String
  twilioCallSid  String?         @unique
  twilioSessionId String?
  fromNumber     String?
  toNumber       String?
  status         VoiceCallStatus @default(IN_PROGRESS)
  transcript     String?         @db.Text
  actionsJson    Json?
  errorMessage   String?
  startedAt      DateTime        @default(now())
  endedAt        DateTime?

  store StoreSetting @relation(fields: [storeKey], references: [storeKey], onDelete: Cascade)

  @@index([storeKey])
  @@index([startedAt])
  @@map("call_logs")
}

model CallSession {
  id        String   @id @default(cuid())
  storeKey  String
  userId    String?
  callLogId String?
  status    VoiceCallStatus @default(IN_PROGRESS)
  startedAt DateTime @default(now())
  endedAt   DateTime?

  store   StoreSetting @relation(fields: [storeKey], references: [storeKey], onDelete: Cascade)
  callLog CallLog?     @relation(fields: [callLogId], references: [id], onDelete: SetNull)

  @@index([storeKey])
  @@index([status])
  @@map("call_sessions")
}

enum CallbackStatus {
  OPEN
  CONTACTED
  CANCELLED
}

model CallbackBooking {
  id             String          @id @default(cuid())
  storeKey       String
  name           String
  phone          String
  preferredTime  String
  notes          String?
  status         CallbackStatus  @default(OPEN)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  store StoreSetting @relation(fields: [storeKey], references: [storeKey], onDelete: Cascade)

  @@index([storeKey])
  @@index([status])
  @@map("callback_bookings")
}
