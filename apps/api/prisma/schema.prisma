// Step 2 — Initial schema for bookstore-voice-agents
// Multi-tenant: Tenant → Stores, Agents, PhoneNumbers, CallSessions, AuditLogs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  SUPPORT
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  DISCONNECTED
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  DISABLED
  PROVISIONING
  READY
  ERROR
}

enum ConnectionStatus {
  UNKNOWN
  OK
  FAILED
}

enum PhoneNumberStatus {
  ACTIVE
  INACTIVE
  UNASSIGNED
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  ESCALATED
  ABANDONED
}

enum KnowledgeDocType {
  FAQ
  POLICY
  SHIPPING_POLICY
  RETURN_POLICY
  STORE_INFO
  BRANCH_INFO
  DELIVERY_INFO
  RETURNS_INFO
  PROMOTION
  HOLIDAY_HOURS
  SOP
  CUSTOM
}

enum KnowledgeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PromptVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ToolExecutionStatus {
  SUCCESS
  FAILED
  TIMEOUT
  BLOCKED
}

enum AgentTypeCode {
  SHOPIFY_VOICE_SALES
}

enum CheckoutMode {
  STOREFRONT_CART
  DRAFT_ORDER_INVOICE
}

enum CheckoutLinkStatus {
  CREATED
  SENT
  OPENED
  COMPLETED
  EXPIRED
  FAILED
}

enum EmailDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum PaymentLifecycleStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users               User[]
  tenantIntegration   TenantIntegration?
  stores              Store[]
  agents              Agent[]
  phoneNumbers        PhoneNumber[]
  calls               CallSession[]
  auditLogs           AuditLog[]
  clients             Client[]
  agentTypes          AgentType[]
  leadCaptures        LeadCapture[]
  checkoutLinks       CheckoutLink[]
  emailEvents         EmailEvent[]
  agentConfigs        AgentConfig[]
  voiceProfiles       VoiceProfile[]
  phoneNumberMappings PhoneNumberMapping[]
  productCaches       ProductCache[]
  variantCaches       VariantCache[]
  paymentRecords      PaymentRecord[]
}

/// Workspace-level integration secrets (encrypted). Never returned to clients in full.
model TenantIntegration {
  id       String @id @default(cuid())
  tenantId String @unique

  shopifyShopDomain    String?
  shopifyAdminTokenEnc String?
  /// Last 4 chars of admin token at save time (display only, not secret).
  shopifyTokenLast4    String?
  shopifyLastTestOk    Boolean?
  shopifyLastTestAt    DateTime?

  twilioAccountSid   String?
  twilioAuthTokenEnc String?
  twilioPhoneNumber  String?
  twilioPhoneSid     String?
  twilioLastTestOk   Boolean?
  twilioLastTestAt   DateTime?

  openaiApiKeyEnc  String?
  openaiKeyLast4   String?
  openaiKeyPrefix  String?
  openaiLastTestOk Boolean?
  openaiLastTestAt DateTime?

  elevenlabsApiKeyEnc       String?
  elevenlabsKeyLast4        String?
  elevenlabsDefaultVoiceId  String?
  elevenlabsDefaultModel    String?
  elevenlabsLastTestOk      Boolean?
  elevenlabsLastTestAt      DateTime?

  resendApiKeyEnc String?
  resendKeyLast4  String?
  resendFromEmail String?
  emailLastTestOk Boolean?
  emailLastTestAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Client {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  contactEmail String?
  contactPhone String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  agents Agent[]

  @@index([tenantId])
}

model AgentType {
  id          String        @id @default(cuid())
  tenantId    String
  code        AgentTypeCode
  name        String
  description String?
  isEnabled   Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  agents Agent[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String
  fullName     String?
  passwordHash String?
  role         UserRole  @default(MANAGER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Store {
  id        String      @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  city      String?
  address   String?
  phone     String?
  email     String?
  timezone  String?
  status    StoreStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  shopifyConnection  ShopifyConnection?
  agents             Agent[]
  knowledgeDocuments KnowledgeDocument[]
  branchProfiles     BranchProfile[]
  storeFaqs          StoreFAQ[]
  calls              CallSession[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model BranchProfile {
  id                String   @id @default(cuid())
  tenantId          String
  storeId           String
  branchCode        String?
  name              String
  city              String?
  area              String?
  address           String?
  phone             String?
  whatsapp          String?
  email             String?
  openingHoursJson  Json?
  pickupAvailable   Boolean  @default(false)
  deliveryAvailable Boolean  @default(false)
  notes             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store              Store               @relation(fields: [storeId], references: [id])
  storeFaqs          StoreFAQ[]
  knowledgeDocuments KnowledgeDocument[]

  @@index([tenantId])
  @@index([storeId])
  @@index([city])
}

model StoreFAQ {
  id              String   @id @default(cuid())
  tenantId        String
  storeId         String
  branchProfileId String?
  question        String
  answer          String
  language        String   @default("en")
  tags            String?
  priority        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id])
  branchProfile BranchProfile? @relation(fields: [branchProfileId], references: [id])

  @@index([tenantId])
  @@index([storeId])
  @@index([branchProfileId])
}

model ShopifyConnection {
  id             String    @id @default(cuid())
  tenantId       String
  storeId        String    @unique
  shopDomain     String
  accessTokenEnc String
  apiVersion     String?
  scopes         String?
  connectedAt    DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store         Store          @relation(fields: [storeId], references: [id])
  checkoutLinks CheckoutLink[]

  @@index([tenantId])
}

model Agent {
  id                         String           @id @default(cuid())
  tenantId                   String
  clientId                   String?
  agentTypeId                String?
  storeId                    String? // optional for create-agent flow
  name                       String
  slug                       String
  description                String?
  language                   String           @default("en")
  timezone                   String?
  voice                      String?
  voiceProvider              String?
  voiceId                    String?
  voiceNameLabel             String?
  voiceStyle                 String?
  baseSystemPrompt           String           @default("")
  greetingMessage            String?
  fallbackMessage            String?
  escalationMessage          String?
  model                      String?
  temperature                Float?
  status                     AgentStatus      @default(DRAFT)
  isPublished                Boolean          @default(false)
  enabledTools               Json?
  /** Dashboard permission toggles; resolved to enabledTools at runtime when enabledTools is empty. */
  toolPermissions            Json?
  maxToolCallsPerTurn        Int?             @default(2)
  handoffEnabled             Boolean          @default(true)
  voiceResponseStyle         String?
  storeName                  String?
  storeUrl                   String?
  storeEmail                 String?
  agentGoal                  String?
  agentRole                  String?
  toneOfVoice                String?
  allowedActions             String?
  restrictedActions          String?
  escalationInstructions     String?
  returnRefundBehavior       String?
  orderStatusHandling        String?
  outOfStockHandling         String?
  transferToHumanEnabled     Boolean          @default(true)
  escalationPhone            String?
  escalationEmail            String?
  shopifyStoreUrl            String?
  shopifyStoreNumber         String?
  knowledgeBaseSource        String?
  knowledgeSyncEnabled       Boolean          @default(true)
  twilioPhoneNumber          String?
  callRoutingMode            String?
  incomingCallHandling       String?
  databaseProvider           String?
  shopifyConnectionStatus    ConnectionStatus @default(UNKNOWN)
  databaseConnectionStatus   ConnectionStatus @default(UNKNOWN)
  twilioConnectionStatus     ConnectionStatus @default(UNKNOWN)
  openaiConnectionStatus     ConnectionStatus @default(UNKNOWN)
  elevenlabsConnectionStatus ConnectionStatus @default(UNKNOWN)
  lastConnectionTestAt       DateTime?
  secretsEnc                 String? // encrypted JSON; never expose to API response
  createdById                String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt
  deletedAt                  DateTime?

  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  store              Store?               @relation(fields: [storeId], references: [id])
  phoneNumbers       PhoneNumber[]
  promptVersions     PromptVersion[]
  calls              CallSession[]
  toolExecutions     ToolExecution[]
  callbackRequests   CallbackRequest[]
  orderBookingDrafts OrderBookingDraft[]
  agentConfig        AgentConfig?
  voiceProfile       VoiceProfile?
  phoneMappings      PhoneNumberMapping[]
  leadCaptures       LeadCapture[]
  checkoutLinks      CheckoutLink[]
  emailEvents        EmailEvent[]
  paymentRecords     PaymentRecord[]
  productCaches      ProductCache[]
  client             Client?              @relation(fields: [clientId], references: [id])
  agentType          AgentType?           @relation(fields: [agentTypeId], references: [id])

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([storeId])
  @@index([twilioPhoneNumber])
  @@index([clientId])
  @@index([agentTypeId])
}

model AgentConfig {
  id                        String       @id @default(cuid())
  tenantId                  String
  agentId                   String       @unique
  supportEmail              String?
  supportPhone              String?
  businessName              String?
  askEmailBeforePaymentLink Boolean      @default(true)
  checkoutMode              CheckoutMode @default(STOREFRONT_CART)
  humanHandoffRules         String?
  shippingPolicy            String?
  returnPolicy              String?
  exchangePolicy            String?
  deliveryNotes             String?
  forbiddenBehaviors        String?
  escalationRules           String?
  fallbackHumanContact      String?
  customSystemPrompt        String?
  emailSenderName           String?
  emailSenderAddress        String?
  emailReplyTo              String?
  emailSubjectTemplate      String?
  paymentLinkEmailIntro     String?
  emailTestRecipient        String?
  useWorkspaceEmail         Boolean      @default(false)
  /** When true, Shopify Admin API uses workspace integration instead of per-agent credentials. */
  useWorkspaceShopify       Boolean      @default(false)
  useWorkspaceOpenai        Boolean      @default(false)
  useWorkspaceElevenlabs    Boolean      @default(false)
  useWorkspaceTwilio        Boolean      @default(false)
  shopifyApiVersion         String?
  metadata                  Json?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model VoiceProfile {
  id              String   @id @default(cuid())
  tenantId        String
  agentId         String   @unique
  provider        String
  language        String   @default("en")
  voice           String?
  tone            String?
  greetingMessage String?
  providerConfig  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model PhoneNumberMapping {
  id               String   @id @default(cuid())
  tenantId         String
  agentId          String
  phoneNumberId    String?
  phoneNumber      String
  provider         String   @default("twilio")
  providerSid      String?
  isPrimaryInbound Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  phoneNumberRef PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)

  @@unique([tenantId, phoneNumber])
  @@index([tenantId])
  @@index([agentId])
  @@index([phoneNumberId])
}

model PhoneNumber {
  id           String            @id @default(cuid())
  tenantId     String
  agentId      String?
  twilioSid    String
  phoneNumber  String
  friendlyName String?
  status       PhoneNumberStatus @default(UNASSIGNED)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  agent               Agent?               @relation(fields: [agentId], references: [id])
  callSessions        CallSession[]
  phoneNumberMappings PhoneNumberMapping[]

  @@index([tenantId])
  @@index([agentId])
  @@unique([tenantId, twilioSid])
  @@unique([tenantId, phoneNumber])
}

model KnowledgeDocument {
  id               String           @id @default(cuid())
  tenantId         String
  storeId          String
  branchProfileId  String?
  title            String
  type             KnowledgeDocType @default(CUSTOM)
  status           KnowledgeStatus  @default(DRAFT)
  language         String           @default("en")
  content          String
  summary          String?
  sourceFileId     String?
  vectorStoreId    String?
  vectorFileId     String?
  metadata         Json?
  isVoiceOptimized Boolean          @default(false)
  createdById      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  store         Store          @relation(fields: [storeId], references: [id])
  branchProfile BranchProfile? @relation(fields: [branchProfileId], references: [id])

  @@index([tenantId])
  @@index([storeId])
  @@index([branchProfileId])
  @@index([type, status])
}

model KnowledgeSourceFile {
  id           String   @id @default(cuid())
  tenantId     String
  storeId      String
  fileName     String
  mimeType     String?
  storageUrl   String
  sizeBytes    Int?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([storeId])
}

enum KnowledgeSyncJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model KnowledgeSyncJob {
  id            String                 @id @default(cuid())
  tenantId      String
  storeId       String
  documentId    String?
  sourceFileId  String?
  vectorStoreId String?
  vectorFileId  String?
  status        KnowledgeSyncJobStatus @default(PENDING)
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime               @default(now())

  @@index([tenantId])
  @@index([storeId])
  @@index([status])
}

model PromptVersion {
  id        String              @id @default(cuid())
  tenantId  String
  agentId   String
  version   Int
  content   String
  status    PromptVersionStatus @default(DRAFT)
  createdAt DateTime            @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@unique([agentId, version])
  @@index([tenantId])
}

enum CallEventType {
  INBOUND_CALL_RECEIVED
  AGENT_RESOLVED
  CALL_SESSION_CREATED
  TWILIO_CONNECTED
  OPENAI_SESSION_STARTED
  TRANSCRIPT_CHUNK_ADDED
  TOOL_CALLED
  TOOL_SUCCEEDED
  TOOL_FAILED
  ESCALATION_TRIGGERED
  FALLBACK_USED
  CALL_COMPLETED
  CALL_FAILED
}

enum CallResolutionStatus {
  RESOLVED
  PARTIALLY_RESOLVED
  UNRESOLVED
  ESCALATED
  ABANDONED
}

model CallSession {
  id              String     @id @default(cuid())
  tenantId        String
  storeId         String? // optional when agent has no linked store
  agentId         String
  phoneNumberId   String?
  twilioCallSid   String?    @unique
  twilioStreamSid String?
  fromNumber      String?
  toNumber        String?
  status          CallStatus @default(INITIATED)
  direction       String? // inbound | outbound
  startedAt       DateTime?
  answeredAt      DateTime?
  endedAt         DateTime?
  durationSeconds Int?
  transcriptText  String?
  summary         String?
  sentiment       String?
  escalated       Boolean    @default(false)
  recordingUrl    String?
  lastEventAt     DateTime?
  metadata        Json?
  openaiSessionId String?
  endedReason     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  store             Store?             @relation(fields: [storeId], references: [id])
  agent             Agent              @relation(fields: [agentId], references: [id])
  phoneNumber       PhoneNumber?       @relation(fields: [phoneNumberId], references: [id])
  transcripts       CallTranscript[]
  toolExecutions    ToolExecution[]
  callEvents        CallEvent[]
  callOutcome       CallOutcome?
  callbackRequests  CallbackRequest[]
  orderBookingDraft OrderBookingDraft?
  leadCaptures      LeadCapture[]
  checkoutLinks     CheckoutLink[]
  emailEvents       EmailEvent[]
  paymentRecords    PaymentRecord[]

  @@index([tenantId])
  @@index([storeId])
  @@index([agentId])
  @@index([agentId, createdAt])
  @@index([phoneNumberId])
  @@index([twilioCallSid])
}

model CallEvent {
  id            String        @id @default(cuid())
  tenantId      String
  callSessionId String
  type          CallEventType
  timestamp     DateTime      @default(now())
  payload       Json?
  createdAt     DateTime      @default(now())

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([callSessionId])
  @@index([type])
  @@index([timestamp])
}

model CallOutcome {
  id                String               @id @default(cuid())
  tenantId          String
  callSessionId     String               @unique
  resolutionStatus  CallResolutionStatus
  primaryIntent     String?
  secondaryIntent   String?
  customerVerified  Boolean              @default(false)
  toolsUsedCount    Int                  @default(0)
  toolFailuresCount Int                  @default(0)
  fallbackCount     Int                  @default(0)
  escalated         Boolean              @default(false)
  callbackRequested Boolean              @default(false)
  summary           String?
  qaScore           Float?
  productsRequested Json?
  conversionOutcome String?
  paymentLinkSent   Boolean              @default(false)
  orderCompleted    Boolean              @default(false)
  escalationReason  String?
  analyticsMeta     Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([resolutionStatus])
}

enum CallbackRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model CallbackRequest {
  id            String                @id @default(cuid())
  tenantId      String
  agentId       String
  callSessionId String?
  phone         String
  reason        String
  priority      String? // low | normal | high
  status        CallbackRequestStatus @default(OPEN)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  agent       Agent        @relation(fields: [agentId], references: [id])
  callSession CallSession? @relation(fields: [callSessionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([agentId])
  @@index([callSessionId])
  @@index([status])
}

enum OrderBookingStatus {
  DRAFT
  READY_FOR_PAYMENT
  CHECKOUT_CREATED
  COMPLETED
  CANCELLED
}

model OrderBookingDraft {
  id                  String             @id @default(cuid())
  tenantId            String
  agentId             String
  callSessionId       String             @unique
  status              OrderBookingStatus @default(DRAFT)
  itemsJson           Json?
  customerJson        Json?
  deliveryAddressJson Json?
  checkoutUrl         String?
  paymentChannel      String? // sms | email
  paymentDestination  String?
  confirmedAt         DateTime?
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  agent       Agent       @relation(fields: [agentId], references: [id])
  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([agentId])
  @@index([status])
}

model AgentQualityReview {
  id                    String   @id @default(cuid())
  tenantId              String
  agentId               String
  callSessionId         String
  reviewerUserId        String?
  accuracyScore         Float?
  toneScore             Float?
  policyComplianceScore Float?
  brevityScore          Float?
  notes                 String?
  needsPromptUpdate     Boolean  @default(false)
  needsFaqUpdate        Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@index([tenantId])
  @@index([agentId])
  @@index([callSessionId])
}

model DailyAgentMetrics {
  id                 String   @id @default(cuid())
  tenantId           String
  agentId            String
  metricDate         DateTime
  totalCalls         Int      @default(0)
  resolvedCalls      Int      @default(0)
  escalatedCalls     Int      @default(0)
  avgDurationSeconds Float?
  avgToolCalls       Float?
  avgToolLatencyMs   Float?
  fallbackRate       Float?
  resolutionRate     Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([agentId, metricDate])
  @@index([tenantId])
}

model CallTranscript {
  id             String   @id @default(cuid())
  callSessionId  String
  role           String // user | agent | system | tool
  content        String
  sequenceNumber Int
  timestampMs    Int?
  createdAt      DateTime @default(now())

  callSession CallSession @relation(fields: [callSessionId], references: [id])

  @@unique([callSessionId, sequenceNumber])
  @@index([callSessionId])
  @@index([createdAt])
}

model LeadCapture {
  id              String   @id @default(cuid())
  tenantId        String
  agentId         String
  callSessionId   String?
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  intent          String?
  interestedItems Json?
  notes           String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  callSession CallSession? @relation(fields: [callSessionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([agentId])
  @@index([agentId, createdAt])
  @@index([callSessionId])
}

model CheckoutLink {
  id                  String             @id @default(cuid())
  tenantId            String
  agentId             String
  callSessionId       String?
  /// Stable hash of mode + email + normalized line items for idempotent checkout per call session.
  checkoutFingerprint String?
  shopifyConnectionId String?
  mode                CheckoutMode       @default(STOREFRONT_CART)
  checkoutUrl         String
  customerEmail       String?
  itemsJson           Json?
  status              CheckoutLinkStatus @default(CREATED)
  providerRef         String?
  expiresAt           DateTime?
  sentAt              DateTime?
  completedAt         DateTime?
  metadata            Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  agent             Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  callSession       CallSession?       @relation(fields: [callSessionId], references: [id], onDelete: SetNull)
  shopifyConnection ShopifyConnection? @relation(fields: [shopifyConnectionId], references: [id], onDelete: SetNull)
  emailEvents       EmailEvent[]
  paymentRecords    PaymentRecord[]

  @@index([tenantId])
  @@index([agentId])
  @@index([agentId, createdAt])
  @@index([callSessionId])
  @@index([tenantId, agentId, callSessionId, checkoutFingerprint])
  @@index([shopifyConnectionId])
  @@index([status])
  @@index([customerEmail])
}

model PaymentRecord {
  id                    String                 @id @default(cuid())
  tenantId              String
  agentId               String
  callSessionId         String?
  checkoutLinkId        String
  customerEmail         String?
  shopifyOrderId        String?
  shopifyOrderName      String?
  paymentStatus         PaymentLifecycleStatus @default(PENDING)
  paidAt                DateTime?
  failedAt              DateTime?
  expiredAt             DateTime?
  /// Stable dedupe key (topic + order id + tenant + checkout link)
  webhookEventKey       String?
  lastWebhookTopic      String?
  rawWebhookPayloadJson Json?
  metadata              Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  agent       Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  callSession CallSession? @relation(fields: [callSessionId], references: [id], onDelete: SetNull)
  checkoutLink CheckoutLink @relation(fields: [checkoutLinkId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([agentId])
  @@index([callSessionId])
  @@index([checkoutLinkId])
  @@index([paymentStatus])
  @@index([customerEmail])
  @@index([shopifyOrderId])
  @@index([createdAt])
  @@unique([tenantId, webhookEventKey])
}

model EmailEvent {
  id                String              @id @default(cuid())
  tenantId          String
  agentId           String
  callSessionId     String?
  checkoutLinkId    String?
  /// Stable key (e.g. SHA-256 hex) so concurrent retries dedupe without relying only on email+checkout.
  idempotencyKey    String?
  recipientEmail    String
  subject           String
  provider          String              @default("resend")
  providerMessageId String?
  status            EmailDeliveryStatus @default(QUEUED)
  bodyPreview       String?
  metadata          Json?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  agent        Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  callSession  CallSession?  @relation(fields: [callSessionId], references: [id], onDelete: SetNull)
  checkoutLink CheckoutLink? @relation(fields: [checkoutLinkId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([agentId])
  @@index([agentId, createdAt])
  @@index([callSessionId])
  @@index([checkoutLinkId])
  @@index([recipientEmail])
  @@index([status])
  @@unique([tenantId, idempotencyKey])
}

model ProductCache {
  id              String   @id @default(cuid())
  tenantId        String
  agentId         String
  shopDomain      String
  shopifyProductId String
  handle          String?
  title           String
  vendor          String?
  productType     String?
  status          String?
  bodyHtml        String?
  tags            String?
  collectionsJson Json?
  rawJson         Json?
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  agent  Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  variants VariantCache[]

  @@unique([tenantId, agentId, shopifyProductId])
  @@index([tenantId])
  @@index([agentId])
  @@index([tenantId, agentId, shopDomain])
  @@index([shopDomain])
  @@index([title])
}

model VariantCache {
  id                String   @id @default(cuid())
  tenantId          String
  productCacheId    String
  shopifyVariantId  String
  sku               String?
  title             String?
  price             Decimal? @db.Decimal(12, 2)
  compareAtPrice    Decimal? @db.Decimal(12, 2)
  inventoryQuantity Int?
  availableForSale  Boolean?
  rawJson           Json?
  syncedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  product ProductCache @relation(fields: [productCacheId], references: [id], onDelete: Cascade)

  @@unique([tenantId, shopifyVariantId])
  @@index([tenantId])
  @@index([sku])
  @@index([title])
}

model ToolExecution {
  id            String              @id @default(cuid())
  tenantId      String
  agentId       String
  callSessionId String?
  requestId     String? // OpenAI request/turn id for tracing
  toolName      String
  inputJson     Json
  outputJson    Json?
  status        ToolExecutionStatus
  errorMessage  String?
  latencyMs     Int?
  createdAt     DateTime            @default(now())

  agent       Agent        @relation(fields: [agentId], references: [id])
  callSession CallSession? @relation(fields: [callSessionId], references: [id])

  @@index([tenantId])
  @@index([agentId])
  @@index([agentId, createdAt])
  @@index([callSessionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
}
