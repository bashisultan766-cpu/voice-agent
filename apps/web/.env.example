# Must match `pnpm dev` in apps/web (fixed to port 3000 in package.json).
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
# Prefer 127.0.0.1 on Windows; Next also normalizes localhost→127.0.0.1 for server-side proxy calls.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
# Server-side only: URL the Next.js Route Handlers use to call Nest (must resolve from the Node process).
# If NEXT_PUBLIC_API_URL points at a Docker-only hostname (e.g. http://api:3001), set this for local dev:
# INTERNAL_API_URL=http://127.0.0.1:3001
INTERNAL_API_URL=

# --- Voice agent (Twilio ConversationRelay + OpenAI) ---
# Dedicated Postgres for voice tables (recommended). Can match DATABASE_URL during local dev if you accept separate Prisma migrations.
VOICE_AGENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_agent
# Public HTTPS base for TwiML → WSS URL construction (no trailing slash). Example: https://abcd-123.ngrok-free.app
VOICE_PUBLIC_BASE_URL=http://127.0.0.1:3000
# Optional: override the full ConversationRelay websocket URL (must be wss:// in production)
# TWILIO_VOICE_RELAY_WS_URL=wss://abcd-123.ngrok-free.app/api/twilio/voice/stream
# Twilio auth token (used for inbound POST + WS signature validation)
TWILIO_AUTH_TOKEN=
# Set to false only for local debugging without signature headers
VALIDATE_TWILIO_SIGNATURES=true
# Optional: same value as apps/api TWILIO_PROXY_SHARED_SECRET so Twilio proxy routes can authenticate to the API.
TWILIO_PROXY_SHARED_SECRET=
# Fallback routing when `To` does not match a `store_settings.storeKey`
VOICE_DEFAULT_STORE_KEY=demo-fashion
# Optional: Twilio <Connect action="..."> callback when ConversationRelay ends
# TWILIO_VOICE_CONNECT_ACTION_URL=https://example.com/api/twilio/voice/connect-action
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional Shopify order lookup (also configurable per-store via POST /api/store/settings)
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=
# Protect store settings CRUD in production
VOICE_ADMIN_API_KEY=
