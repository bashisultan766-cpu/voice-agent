# ==============================================================================
# SureShot Books — Order Lookup Voice Agent (TypeScript)
# Copy to .env and fill in real values. NEVER commit .env.
# ==============================================================================

PORT=8001
PUBLIC_BASE_URL=https://agent.mailcallcommunication.com
LOG_LEVEL=info

# --- Twilio (voice transport only — Twilio NEVER generates speech) -----------
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
VALIDATE_TWILIO_SIGNATURES=true

# Twilio webhook URLs:
#   Voice URL:  https://your-domain/voice/twilio/inbound
#   Status URL: https://your-domain/voice/twilio/status  (optional)

# --- OpenAI (conversation brain + intent classification) ----------------------
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
CONVERSATION_BRAIN_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=8000

# --- Shopify ------------------------------------------------------------------
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=replace_me
SHOPIFY_API_VERSION=2024-01
SHOPIFY_TIMEOUT_MS=10000
SHOPIFY_CACHE_TTL_SECS=60

# --- ElevenLabs (ALL text-to-speech — required) -------------------------------
ELEVENLABS_API_KEY=replace_me
VOICE_ID=your_elevenlabs_voice_id_here
ELEVENLABS_MODEL=eleven_turbo_v2_5
VOICE_STABILITY=0.42
VOICE_SIMILARITY=0.78
VOICE_LANGUAGE=en-US

# --- Audio cache (MP3 files served via TwiML <Play>) --------------------------
AUDIO_CACHE_DIR=./audio-cache
AUDIO_CACHE_TTL_MS=3600000

ORDER_LOOKUP_MAX_RETRIES=2

# Emergency mode — skip Shopify product search
SAFE_MODE=false
