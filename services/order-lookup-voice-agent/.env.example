# ==============================================================================
# SureShot Books — Order Lookup Voice Agent (TypeScript)
# Copy to .env and fill in real values. NEVER commit .env.
# ==============================================================================

PORT=8001
PUBLIC_BASE_URL=https://example.com
LOG_LEVEL=info

# --- Twilio -------------------------------------------------------------------
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
VALIDATE_TWILIO_SIGNATURES=true

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
CONVERSATION_BRAIN_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=8000

# --- Shopify ------------------------------------------------------------------
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_replace_me
SHOPIFY_API_VERSION=2025-07
SHOPIFY_TIMEOUT_MS=10000
SHOPIFY_CACHE_TTL_SECS=60

# --- ElevenLabs via Twilio ConversationRelay (copy VOICE_ID from old Python .env)
# Twilio expects model slugs WITHOUT the eleven_ prefix (e.g. flash_v2_5, not eleven_flash_v2_5).
VOICE_TTS_PROVIDER=ElevenLabs
# twilio_conversation_relay — Eric voice via VOICE_ID (Twilio synthesizes; no API key)
# twilio_media_streams — direct ElevenLabs API (requires ELEVENLABS_API_KEY)
VOICE_RUNTIME=twilio_conversation_relay
# Set true only to force OpenAI tts-1-hd (skips ElevenLabs entirely). Leave false for Eric voice ID.
VOICE_IDENTITY_CONSTRAINT=false
VOICE_ID=your_elevenlabs_voice_id_here
VOICE_MODEL=turbo_v2_5
# Quality tuning for Twilio ConversationRelay (speed 0.7–1.2, stability/similarity 0.0–1.0)
# Studio-quality defaults: high stability + similarity, low style exaggeration
VOICE_SPEED=0.92
VOICE_STABILITY=0.70
VOICE_SIMILARITY=0.85
VOICE_STYLE=0.0
TTS_AUDIO_FORMAT=ulaw_8000
VOICE_TUNING_ENABLED=true
ELEVENLABS_TEXT_NORMALIZATION=on
VOICE_LANGUAGE=en-US
ELEVENLABS_API_KEY=optional

ORDER_LOOKUP_MAX_RETRIES=2

# Emergency mode — skip Shopify product search and embeddings
SAFE_MODE=false

# --- Resend (checkout + support escalation emails) ---------------------------
RESEND_API_KEY=replace_me
RESEND_FROM_EMAIL=orders@sureshotbooks.com
RESEND_FROM_NAME=SureShot Books
SUPPORT_EMAIL=jessica@sureshotbooks.com
