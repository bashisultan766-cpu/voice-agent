# ==============================================================================
# SureShot Books — Order Lookup Voice Agent (TypeScript)
# Copy to .env and fill in real values. NEVER commit .env.
# ==============================================================================

PORT=8001
PUBLIC_BASE_URL=https://example.com
LOG_LEVEL=info

# --- Twilio -------------------------------------------------------------------
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
VALIDATE_TWILIO_SIGNATURES=true

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=8000

# --- Shopify ------------------------------------------------------------------
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=replace_me
SHOPIFY_API_VERSION=2024-01
SHOPIFY_TIMEOUT_MS=10000
SHOPIFY_CACHE_TTL_SECS=60

# --- ElevenLabs (Eric voice via Twilio ConversationRelay + optional direct TTS)
ELEVENLABS_API_KEY=optional
ELEVENLABS_VOICE_ID=Eric
VOICE_LANGUAGE=en-US
VOICE_TTS_PROVIDER=ElevenLabs

ORDER_LOOKUP_MAX_RETRIES=2

# Must match voice-router VOICE_ROUTER_FORWARD_SECRET
VOICE_ROUTER_FORWARD_SECRET=replace_with_long_random_secret
