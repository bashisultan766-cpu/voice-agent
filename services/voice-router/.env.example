# ==============================================================================
# SureShot Books — Voice Router (single Twilio entrypoint, port 8000)
# ==============================================================================

PORT=8000
PUBLIC_BASE_URL=https://example.com
LOG_LEVEL=info

TWILIO_AUTH_TOKEN=replace_me
VALIDATE_TWILIO_SIGNATURES=true

# Shared secret — must match order-lookup + main Python agent .env
VOICE_ROUTER_FORWARD_SECRET=replace_with_long_random_secret

# Internal downstream URLs (nginx proxies public paths to these ports)
ORDER_LOOKUP_INBOUND_URL=http://127.0.0.1:8002/voice/order/twilio/inbound
MAIN_AGENT_INBOUND_URL=http://127.0.0.1:8001/voice/twilio/agent/inbound
ORDER_LOOKUP_HEALTH_URL=http://127.0.0.1:8002/health

AGENT_FORWARD_TIMEOUT_MS=8000
HEALTH_CHECK_TIMEOUT_MS=2000
SESSION_TTL_SECS=3600
GATHER_TIMEOUT_SECS=5

# OpenAI — intent classification + conversation brain for non-order speech
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
CONVERSATION_BRAIN_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=5000
