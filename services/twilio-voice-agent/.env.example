# ==============================================================================
# Twilio ConversationRelay Voice Agent â€” Environment Template
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ==============================================================================

# --- Runtime ------------------------------------------------------------------
VOICE_RUNTIME=twilio_conversation_relay

# Public HTTPS base URL for this service (no trailing slash).
# In dev: use ngrok -> https://abc123.ngrok.io
# In prod: your actual domain, e.g. https://voice.example.com
# ConversationRelay WebSocket URL derives from this automatically.
PUBLIC_BASE_URL=https://example.com

DEBUG=false
LOG_LEVEL=info

# development | test | production
# production: REDIS_URL required, no in-memory session fallback, API docs disabled
APP_ENV=development

# Signed WebSocket token validation (recommended true in production)
WS_TOKEN_VALIDATION_ENABLED=true

# Optional dedicated HMAC secret for WS tokens (defaults to INTERNAL_ADMIN_KEY / TWILIO_AUTH_TOKEN)
# WS_TOKEN_SECRET=

# Enable FastAPI /docs and /openapi.json (auto-disabled in production unless DEBUG=true)
ENABLE_API_DOCS=true

# --- Twilio -------------------------------------------------------------------
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=+15551234567

# Validate webhook signatures in production. Set false for local dev with ngrok.
VALIDATE_TWILIO_SIGNATURES=true

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=replace_me

# Model used for all voice turns. gpt-4o-mini is fast and cheap.
OPENAI_MODEL=gpt-4o-mini

# Hard timeout for each OpenAI request (seconds).
OPENAI_TIMEOUT_SECS=30.0

# --- Shopify ------------------------------------------------------------------
# Store domain without https:// â€” e.g. your-store.myshopify.com
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# Admin API access token (shpat_... format).
# Required scopes: read_products, read_orders, write_draft_orders
SHOPIFY_ADMIN_ACCESS_TOKEN=replace_me

# Shopify Admin API version.
SHOPIFY_API_VERSION=2026-01

# Per-request timeout for Shopify API calls (seconds).
SHOPIFY_TIMEOUT_SECS=10.0

# Product search cache TTL in Redis (seconds).
SHOPIFY_CACHE_TTL_SECS=60

# --- Redis --------------------------------------------------------------------
# Used for session state and Shopify result caching.
# If unavailable, the service falls back to in-process memory (single instance only).
REDIS_URL=redis://127.0.0.1:6379

# --- Database (optional) ------------------------------------------------------
# PostgreSQL connection for writing call logs.
# Leave blank if not using DB call logging.
DATABASE_URL=postgresql://user:pass@localhost:5432/voice_agent
# Fail fast when Postgres is required but unavailable (default: false)
STRICT_POSTGRES=false
# Enable GET /admin/sessions/{id}/timeline and /replay (X-Admin-Key required)
ENABLE_ADMIN_DEBUG_ENDPOINTS=false
# Set true only with ALLOW_ADMIN_DEBUG_IN_PRODUCTION=true in production
# ALLOW_ADMIN_DEBUG_IN_PRODUCTION=false
# Optional LLM refinement for post-call evaluation scores (default: deterministic only)
ENABLE_LLM_EVAL=false

# --- Resend (email for payment links) -----------------------------------------
# Create a free account at resend.com. Required for send_payment_link_email tool.
RESEND_API_KEY=replace_me
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Bookstore Support
# Optional: reply-to address and escalation email for support notifications.
SUPPORT_EMAIL=jessica@sureshotbooks.com
# Product-not-found escalation (Step 5)
SUPPORT_ESCALATION_ENABLED=true
# Optional dedicated from-address for escalation emails (defaults to RESEND_FROM_*)
# SUPPORT_ESCALATION_FROM_EMAIL=Voice Agent <noreply@example.com>

# --- Pipeline speed budgets ---------------------------------------------------
# All values are in milliseconds unless noted.
# How long the first caller turn waits for the caller profile to load.
VOICE_FIRST_PROMPT_PROFILE_TIMEOUT_MS=750
# Per-tool timeout for speculative prefetch AND live tool calls.
VOICE_TOOL_TIMEOUT_MS=2500
# Shopify GraphQL per-request timeout.
VOICE_SHOPIFY_TIMEOUT_MS=2500
# OpenAI streaming call hard timeout.
VOICE_OPENAI_TIMEOUT_MS=8000
# Emit a filler phrase if tools haven't responded within this window.
VOICE_FILLER_AFTER_MS=250
# Soft limit on LLM reply length (words) â€” keeps responses voice-friendly.
VOICE_MAX_REPLY_WORDS=50

# --- Shopify webhooks ---------------------------------------------------------
# Secret used to verify X-Shopify-Hmac-SHA256 on incoming Shopify webhooks.
# Set this when registering webhooks in Shopify admin (Settings â†’ Notifications).
# Required for /webhooks/shopify/* endpoints to reject unsigned requests.
SHOPIFY_WEBHOOK_SECRET=replace_me

# --- Admin -------------------------------------------------------------------
# Protects the POST /admin/sync endpoint (X-Admin-Key header).
# Use a strong random string; never commit this value.
INTERNAL_ADMIN_KEY=replace_me

# --- Legacy â€” disabled for new runtime ----------------------------------------
# These flags are read at startup. Both must be false for ConversationRelay runtime.
# Deepgram and ElevenLabs are not used by this service â€” their SDKs are not installed.
ENABLE_ELEVENLABS=false
ENABLE_DEEPGRAM=false

# --- v4.6 ElevenLabs voice via Twilio ConversationRelay -------------------------
VOICE_TTS_PROVIDER=ElevenLabs
VOICE_ID=your_elevenlabs_voice_id_here
VOICE_MODEL=eleven_turbo_v2_5
VOICE_SPEED=0.96
VOICE_STABILITY=0.42
VOICE_SIMILARITY=0.78
VOICE_SPEED=1.0
VOICE_STABILITY=0.55
VOICE_SIMILARITY=0.80
VOICE_LANGUAGE=en-US
ELEVENLABS_API_KEY=optional_for_future_direct_tts_do_not_commit_real_key

# --- v4.12 Welcome greeting + LLM-first final speaker -------------------------
VOICE_WELCOME_GREETING_ENABLED=true
VOICE_WELCOME_GREETING=Hello! Thank you for calling SureShot Books. How can I help you today?
VOICE_WELCOME_GREETING_INTERRUPTIBLE=any
VOICE_FINAL_RESPONSE_MODE=llm_first
VOICE_FINAL_LLM_FOR_SMALL_TALK=true
VOICE_FINAL_LLM_FOR_UNKNOWN=true
VOICE_FINAL_LLM_FOR_OUT_OF_DOMAIN=true
VOICE_FINAL_LLM_FOR_CLARIFICATION=true

# --- v4.18 LLM-first tool runtime (single active runtime) --------------------
# The only supported live runtime. Dispatch always routes caller turns here, so
# legacy mode values (main_llm_agent / eric_agent_runtime / legacy_v410 /
# llm_first) are ignored. Leave as llm_tool_runtime.
VOICE_AGENT_RUNTIME_MODE=llm_tool_runtime
# Step 4 orchestrator — supervisor → planner → tools → composer (default on)
VOICE_ORCHESTRATOR_ENABLED=true
VOICE_LEGACY_RUNTIME_FALLBACK_ENABLED=true
# Optional OpenTelemetry (disabled by default)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_STRONG_MODEL=gpt-4o
# Main commerce brain model for live calls (gpt-4o = stronger, gpt-4o-mini = cheaper).
VOICE_BRAIN_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini
# Approx system-prompt token budget; above it the master prompt is sent
# section-by-section (privacy/payment/tool-safety sections always included).
VOICE_PROMPT_TOKEN_BUDGET=4000
# Single master system prompt file used by the LLM-first runtime:
#   app/data/agent_master_system_prompt.md

# --- DEPRECATED prompt systems (archived 2026-06-26) -------------------------
# Live runtime: app/data/agent_master_system_prompt.md — see app/prompts/README.md
ERIC_SYSTEM_PROMPT_PATH=app/data/agent_master_system_prompt.md
ERIC_SYSTEM_PROMPT_VERSION=archived
ERIC_PROMPT_PACK_DIR=archive_legacy/data/prompt_pack
ERIC_PROMPT_PACK_ENABLED=false
ERIC_PROMPT_PACK_REQUIRE_ALL=false
VOICE_ISBN_PARTIAL_TIMEOUT_MS=5000
VOICE_COLLECTION_MAX_HOLD_MS=7000
VOICE_COLLECTION_KEEPALIVE_ENABLED=true

