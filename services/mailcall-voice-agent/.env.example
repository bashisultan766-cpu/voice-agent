# Public HTTPS origin Twilio can reach (no trailing slash)
# Production: https://agent.mailcallcommunication.com
MAILCALL_PUBLIC_BASE_URL=https://agent.mailcallcommunication.com

# Twilio (Mail Call number — isolated from other agents)
MAILCALL_TWILIO_PHONE_NUMBER=+12014290422
# Required for signature validation (Twilio Console → Account → Auth Token)
# Must be the Auth Token for the SAME account that owns +12014290422
MAILCALL_TWILIO_AUTH_TOKEN=
# Validate signatures when token is set (empty token ⇒ checks skipped)
MAILCALL_VALIDATE_TWILIO_SIGNATURES=true
# false (default): log bad signatures but still return ConversationRelay
# true: reject bad signatures with technical-difficulties TwiML
MAILCALL_TWILIO_SIGNATURE_STRICT=false

# WordPress REST API (Application Password auth)
MAILCALL_WP_URL=https://mailcall.example
MAILCALL_WP_USER=editor
MAILCALL_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional OpenAI for conversational turns (falls back to retrieval-only speech if unset)
MAILCALL_OPENAI_API_KEY=
MAILCALL_OPENAI_MODEL=gpt-4o-mini

# Cache / latency
MAILCALL_CACHE_TTL_MS=60000
MAILCALL_WP_TIMEOUT_MS=2500
MAILCALL_PORT=8010
MAILCALL_LOG_LEVEL=info
