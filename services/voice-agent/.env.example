# ═══════════════════════════════════════════════════════════════════════════════
# SureShot Books — Voice Agent Service
# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit real secrets to version control.
# ═══════════════════════════════════════════════════════════════════════════════


# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Public HTTPS base URL for this service.
# Twilio webhooks, Media Streams WebSocket, and audio file URLs are built from this.
# In dev: use ngrok → https://your-id.ngrok.io
# In prod: your actual domain, e.g. https://voice.sureshotbooks.com
# MUST be https:// — Twilio Media Streams requires wss://, which derives from this.
BASE_URL=https://your-ngrok-url.ngrok.io


# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The Twilio phone number that receives inbound calls (E.164 format).
TWILIO_PHONE_NUMBER=+15550000000
# Validates every inbound webhook signature. Set to true in production.
# Can be false in local dev (ngrok URLs change and Twilio won't match).
TWILIO_VALIDATE_REQUESTS=true


# ── LLM (OpenAI) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model — cheap and fast. Used for most conversational turns.
# gpt-4o-mini: ~$0.15/1M input tokens
LLM_MODEL=gpt-4o-mini

# Escalation model — only used when a complex multi-tool chain is detected.
# gpt-4o: ~$2.50/1M input tokens
LLM_ESCALATION_MODEL=gpt-4o

# Number of conversation turns kept in the LLM context window.
# Each turn = 2 messages (user + assistant). 10 turns = 20 messages.
LLM_HISTORY_WINDOW=10

# Max tokens the LLM may generate per turn (keeps responses short for voice).
LLM_MAX_TOKENS_PER_TURN=400


# ── STT — Speech-to-Text ─────────────────────────────────────────────────────
# Choices: deepgram | openai
# deepgram: streaming, interim results, speech_final endpointing (~$0.004/min)
# openai:   higher latency fallback — buffers full utterance before transcribing
STT_PROVIDER=deepgram

# Required when STT_PROVIDER=deepgram.
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── TTS — Text-to-Speech ─────────────────────────────────────────────────────
# Choices: openai | elevenlabs
# openai:     streaming, tts-1 model (~$15/1M chars), decent quality
# elevenlabs: streaming, higher quality (~$22/1M chars), same interface
TTS_PROVIDER=openai

# OpenAI TTS settings (active when TTS_PROVIDER=openai).
# Voice options: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
OPENAI_TTS_SPEED=1.0

# ElevenLabs settings (active when TTS_PROVIDER=elevenlabs).
# Leave blank if using OpenAI TTS.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=


# ── Shopify ───────────────────────────────────────────────────────────────────
# true  = use mock order/product data (safe build phase — no real API calls)
# false = hit the real Shopify Admin REST API (requires domain + token below)
SHOPIFY_USE_MOCK=true

# Your Shopify store domain (no https://).
SHOPIFY_DOMAIN=your-store.myshopify.com

# Shopify Admin API access token (shpat_... format).
# Needs scopes: read_orders, write_draft_orders, read_products.
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Agent Backend API ─────────────────────────────────────────────────────────
# Base URL for the NestJS backend that powers the 13 voice tools.
# Tools call e.g.: GET {AGENT_API_BASE}/v1/orders/{number}
# Leave blank during safe build phase — tools use mock data.
AGENT_API_BASE=https://api.your-backend.example.com

# Bearer token / API key sent in the Authorization header.
AGENT_API_KEY=your-internal-api-key


# ── Email (Resend) ────────────────────────────────────────────────────────────
# Used by send_payment_link and send_facility_payment_link tools.
# Leave blank during safe build phase — email stub is active (no real sends).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=orders@sureshotbooks.com


# ── Cost Control & Safety ─────────────────────────────────────────────────────
# Disconnect the call after this many seconds (hard safety cap).
MAX_CALL_DURATION_S=300

# Total cumulative token budget across all LLM turns in one call.
# When exceeded, the bot apologizes and ends the call gracefully.
MAX_TOKENS_PER_CALL=8000

# Emit a structured cost/token summary log line at the end of each call.
COST_LOG_ENABLED=true


# ── Internal / v2 Tool Settings ───────────────────────────────────────────────
# Customer service escalation email (used by escalate_to_customer_service tool).
CS_EMAIL=jessica@sureshotbooks.com


# ── Single-Tenant Defaults (Phase 1) ─────────────────────────────────────────
# SINGLE_TENANT note: DEFAULT_TENANT_ID / DEFAULT_AGENT_ID machinery is
# removable for single-client deployments. Kept for backward compatibility.
DEFAULT_AGENT_ID=default
DEFAULT_TENANT_ID=default
DEFAULT_AGENT_NAME=Alex
DEFAULT_BUSINESS_NAME=SureShot Books
# Voice: per-tenant AgentConfig.voice_id overrides OPENAI_TTS_VOICE if set.


# ── Audio Cache ───────────────────────────────────────────────────────────────
# Local directory for pre-synthesized TTS MP3 files (served as static files).
# Twilio fetches audio from {BASE_URL}/audio/{hash}.mp3
# Note: not used in the Media Streams WebSocket pipeline (audio is streamed inline).
AUDIO_CACHE_DIR=./audio_cache


# ── Redis (optional) ──────────────────────────────────────────────────────────
# Leave blank to use the in-memory session store.
# Set a Redis URL for multi-instance deployments or persistent sessions.
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=
