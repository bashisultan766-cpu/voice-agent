{
  "name": "bookstore-voice-agents",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev": "turbo dev",
    "dev:local": "concurrently -k -n api,web -c blue,magenta \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:web": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-web.ps1",
    "dev:api": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-api.ps1",
    "dev:reset-ports": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-reset-ports.ps1",
    "dev:doctor": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-doctor.ps1",
    "dev:bootstrap": "pnpm --filter api run dev:bootstrap",
    "dev:simulate-tool": "pnpm --filter api run dev:simulate-tool",
    "dev:simulate-voice-flow": "pnpm --filter api run dev:simulate-voice-flow",
    "dev:preflight-voice-flow": "pnpm --filter api run dev:preflight-voice-flow",
    "dev:test-phone-mapping": "pnpm --filter api run dev:test-phone-mapping",
    "dev:sync-shopify": "pnpm --filter api run dev:sync-shopify",
    "dev:test-checkout-link": "pnpm --filter api run dev:test-checkout-link",
    "dev:test-email-send": "pnpm --filter api run dev:test-email-send",
    "prebuild": "pnpm db:generate && pnpm db:voice:generate",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter api exec prisma generate",
    "prisma:generate": "pnpm --filter api exec prisma generate",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:reset": "pnpm --filter api exec prisma migrate reset --force",
    "db:studio": "pnpm --filter api exec prisma studio",
    "db:voice:generate": "cross-env VOICE_AGENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_agent pnpm --filter @bookstore-voice-agents/voice-db run generate",
    "db:voice:migrate": "cross-env VOICE_AGENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_agent pnpm --filter @bookstore-voice-agents/voice-db run migrate",
    "db:voice:migrate:deploy": "cross-env VOICE_AGENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_agent pnpm --filter @bookstore-voice-agents/voice-db run migrate:deploy",
    "db:voice:seed": "cross-env VOICE_AGENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voice_agent pnpm --filter @bookstore-voice-agents/voice-db run seed",
    "deploy:vps": "bash scripts/vps-deploy.sh"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
