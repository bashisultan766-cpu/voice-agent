{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "twilio-voice-agent: test",
      "type": "shell",
      "command": "python -m pytest -q",
      "options": {
        "cwd": "${workspaceFolder}/services/twilio-voice-agent"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "twilio-voice-agent: dev server",
      "type": "shell",
      "command": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8001",
      "options": {
        "cwd": "${workspaceFolder}/services/twilio-voice-agent"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
